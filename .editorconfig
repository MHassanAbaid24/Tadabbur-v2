# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Don't use Microsoft line endings; keep Unix style
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# TypeScript/React/CSS/HTML Frontend
[*.{ts,tsx,js,jsx,css,html,json}]
indent_style = space
indent_size = 2

# Python Backend
[*.py]
indent_style = space
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false
