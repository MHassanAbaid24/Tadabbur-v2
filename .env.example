# Quran Foundation API Credentials
# Request access: https://api-docs.quran.foundation/request-access
QF_CLIENT_ID=your_client_id_here
QF_CLIENT_SECRET=your_client_secret_here
QF_ENV=prelive  # "prelive" for development, "production" for live
QF_TEST_USER_TOKEN=  # Optional: hardcoded user token for demo (skips OAuth flow)

# Supabase (PostgreSQL Database & Auth)
# Get from your Supabase project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here  # Server-side only, never expose to frontend

# Gemini API Configuration (via OpenAI SDK Compatibility layer)
# Get your API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# JWT Configuration
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your_random_64_char_secret_here
JWT_EXPIRY_HOURS=168  # 7 days

# Frontend URL (for CORS in backend)
FRONTEND_URL=http://localhost:5173

# Gmail SMTP for OTP Email Verification
# Generate App Password: https://myaccount.google.com/apppasswords
GMAIL_SENDER_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_RESEND_ATTEMPTS=3
OTP_RESEND_COOLDOWN_MINUTES=10
OTP_MAX_VERIFICATION_ATTEMPTS=5

# Frontend Supabase (anon key only — safe to expose)
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here  # Public key only
